# Spotify WaveMood - Phase 6 Environment Variables

# API Base URL
# For local development with mock data, this can be any value
# For full Spotify integration, set to your backend server URL
VITE_API_BASE_URL=http://localhost:3001

# Note: Phase 6 uses mock data for recommendations.
# For full Spotify API integration, you'll need to set up a backend server
# with the following environment variables in the backend .env:
#
# SPOTIFY_CLIENT_ID=your_client_id
# SPOTIFY_CLIENT_SECRET=your_client_secret
# SPOTIFY_REDIRECT_URI=http://localhost:3001/api/auth/callback
# SESSION_SECRET=your_session_secret
# PORT=3001
# FRONTEND_URL=http://localhost:5173
